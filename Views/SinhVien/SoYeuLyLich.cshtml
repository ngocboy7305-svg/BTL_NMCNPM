@model QuanLySinhVien.Models.SinhVienModel
@{
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
    ViewBag.Title = "Sơ yếu lý lịch";
}

<div class="page-title">Sơ yếu lý lịch</div>

<div class="card">
    <div class="info-grid">

        <label>Mã sinh viên</label>
        <input type="text" value="@Model.MaSinhVien" readonly />

        <label>Họ tên</label>
        <input type="text" value="@Model.TenSinhVien" readonly />

        <label>Ngày sinh</label>
        <input type="date" value="@(Model.NgaySinh?.ToString("yyyy-MM-dd"))" readonly />

        <label>Giới tính</label>
        <input type="text" value="@Model.GioiTinh" readonly />

        <label>Lớp hành chính</label>
        <input type="text" value="@Model.LopHanhChinh" readonly />

        <label>Email</label>
        <input type="text" value="@Model.Email" readonly />

        <label>Số điện thoại</label>
        <input type="text" value="@Model.SoDienThoai" readonly />

    </div>
</div>