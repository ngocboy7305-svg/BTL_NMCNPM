<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="icon" href="~/Content/images/logo.jpg" />
    <link href="~/Content/Css/portal.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>
<body class="portal-page">
    <div class="portal-wrapper">
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="fa-solid fa-graduation-cap"></i>
                <span>@ViewBag.PortalTitle</span>
            </div>

            <ul class="menu">
                @if ((string)ViewBag.Role == "SV")
                {
                    <li>
                        <a href="@Url.Action("Index", "SinhVien")">
                            <i class="fa-solid fa-house"></i> Trang chủ
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("SoYeuLyLich", "SinhVien")">
                            <i class="fa-regular fa-address-card"></i> Sơ yếu lý lịch
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("DangKyTin", "SinhVien")">
                            <i class="fa-regular fa-pen-to-square"></i> Đăng ký học phần
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("DiemThi", "SinhVien")">
                            <i class="fa-regular fa-file-lines"></i> Xem điểm
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("LichHocKy", "SinhVien")">
                            <i class="fa-regular fa-calendar-days"></i> Lịch học kỳ
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("LichHocTheoTuan", "SinhVien")">
                            <i class="fa-solid fa-calendar-week"></i> Lịch học tuần
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("LichThi", "SinhVien")">
                            <i class="fa-regular fa-calendar"></i> Lịch thi
                        </a>
                    </li>
                }

                @if ((string)ViewBag.Role == "ADMIN")
                {
                    <li>
                        <a href="@Url.Action("ThongKe", "Admin")">
                            <i class="fa-solid fa-chart-column"></i> Thống kê
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ThemSinhVien", "Admin")">
                            <i class="fa-solid fa-user-plus"></i> Thêm sinh viên
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ThemLopHocPhan", "Admin")">
                            <i class="fa-solid fa-plus"></i> Thêm lớp học phần
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("MonHoc", "Admin")">
                            <i class="fa-solid fa-book"></i> Môn học
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("ThemGiangVien", "Admin")">
                            <i class="fa-solid fa-chalkboard-user"></i> Thêm Giảng viên
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("XepLichThi", "Admin")">
                            <i class="fa-regular fa-calendar"></i> Lịch thi
                        </a>
                    </li>
                }

                @if ((string)ViewBag.Role == "GV")
                {
                    <li>
                        <a href="@Url.Action("LopGiangDay", "GiangVien")">
                            <i class="fa-solid fa-book-open"></i> Lớp giảng dạy
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("NhapDiem", "GiangVien")">
                            <i class="fa-solid fa-pen"></i> Nhập điểm
                        </a>
                    </li>
                    <li>
                        <a href="@Url.Action("DiemDanh", "GiangVien")">
                            <i class="fa-solid fa-list-check"></i> Điểm danh
                        </a>
                    </li>
                }
            </ul>
        </aside>

        <main class="main-content">
            <div class="topbar">
                <div></div>

                <div class="user-menu">
                    <button type="button" class="user-btn" onclick="toggleDropdown()">
                        <i class="fa-regular fa-circle-user"></i>
                        @(Session["HoTen"] ?? ViewBag.UserName ?? "Người dùng")
                        <i class="fa-solid fa-caret-down"></i>
                    </button>

                    <div class="dropdown-menu" id="userDropdown">
                        <a href="@Url.Action("Logout", "Account")">Đăng xuất</a>
                    </div>
                </div>
            </div>

            <div class="page-content">
                @RenderBody()
            </div>
        </main>
    </div>

    <script>
        function toggleDropdown() {
            document.getElementById("userDropdown").classList.toggle("show");
        }

        window.onclick = function (e) {
            if (!e.target.closest('.user-menu')) {
                var dropdown = document.getElementById("userDropdown");
                if (dropdown.classList.contains("show")) {
                    dropdown.classList.remove("show");
                }
            }
        }
    </script>
</body>
</html>