@model List<QuanLySinhVien.Models.LichGiangDayViewModel>

@{
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
    ViewBag.Title = "Lịch giảng dạy";
}

<div class="page-title">Lịch giảng dạy</div>

<div class="card">
    <table class="table">
        <thead>
            <tr>
                <th>Mã LHP</th>
                <th>Môn học</th>
                <th>Giảng viên</th>
                <th>Học kỳ</th>
                <th>Năm học</th>
                <th>Thứ</th>
                <th>Tiết</th>
                <th>Phòng</th>
                <th>Ngày bắt đầu</th>
                <th>Ngày kết thúc</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.MaLopHocPhan</td>
                        <td>@item.TenMonHoc</td>
                        <td>@item.TenGiangVien</td>
                        <td>@item.HocKy</td>
                        <td>@item.NamHoc</td>
                        <td>@item.Thu</td>
                        <td>@item.TietBatDau - @item.TietKetThuc</td>
                        <td>@item.PhongHoc</td>
                        <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                        <td>@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="10">Chưa có lịch giảng dạy nào</td>
                </tr>
            }
        </tbody>
    </table>
</div>