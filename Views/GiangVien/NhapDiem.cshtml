@model List<QuanLySinhVien.Models.DiemViewModel>
@using System.Web.Mvc
@{
    Layout = "~/Views/Shared/_PortalLayout.cshtml";
    ViewBag.Title = "Nhập điểm";
    var dsLopHocPhan = ViewBag.DanhSachLopHocPhan as List<SelectListItem>;
}

<div class="page-title">Nhập điểm</div>

<div class="card">
    @using (Html.BeginForm("NhapDiem", "GiangVien", FormMethod.Get))
    {
        <div style="margin-bottom:15px;">
            <label><strong>Chọn lớp học phần:</strong></label>
            <select name="maLopHocPhan" style="padding:8px; min-width:300px;">
                <option value="">-- Chọn lớp học phần --</option>
                @if (dsLopHocPhan != null)
                {
                    foreach (var item in dsLopHocPhan)
                    {
                        <option value="@item.Value" @(ViewBag.MaLopHocPhan != null && ViewBag.MaLopHocPhan.ToString() == item.Value ? "selected" : "")>
                            @item.Text
                        </option>
                    }
                }
            </select>

            <button type="submit" class="btn btn-search">Xem danh sách</button>
        </div>
    }

    <p><strong>Mã lớp học phần:</strong> @ViewBag.MaLopHocPhan</p>

    @if (TempData["Message"] != null)
    {
        <p style="color:green">@TempData["Message"]</p>
    }

    @if (TempData["Error"] != null)
    {
        <p style="color:red">@TempData["Error"]</p>
    }

    @if (ViewBag.Error != null)
    {
        <p style="color:red">@ViewBag.Error</p>
    }

    <table class="table">
        <thead>
            <tr>
                <th>Mã SV</th>
                <th>Tên sinh viên</th>
                <th>Chuyên cần</th>
                <th>Giữa kỳ</th>
                <th>Cuối kỳ</th>
                <th>Tổng kết</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                foreach (var item in Model)
                {
                    <tr>
                        @using (Html.BeginForm("LuuDiem", "GiangVien", FormMethod.Post))
                        {
                            <td>
                                @item.MaSinhVien
                                <input type="hidden" name="maSinhVien" value="@item.MaSinhVien" />
                            </td>
                            <td>@item.TenSinhVien</td>
                            <td>
                                <input type="number" step="0.1"  name="diemChuyenCan" value="@item.DiemChuyenCan" />
                            </td>
                            <td>
                                <input type="number" step="0.1"  name="diemGiuaKy" value="@item.DiemGiuaKy" />
                            </td>
                            <td>
                                <input type="number" step="0.1"  name="diemCuoiKy" value="@item.DiemCuoiKy" />
                            </td>
                            <td>
                                @(item.DiemTongKet.HasValue ? item.DiemTongKet.Value.ToString("0.0") : "")
                            </td>
                            <td>
                                <input type="hidden" name="maLopHocPhan" value="@item.MaLopHocPhan" />
                                <button type="submit" class="btn btn-save">Lưu</button>
                            </td>
                        }
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">Chưa có sinh viên trong lớp học phần này</td>
                </tr>
            }
        </tbody>
    </table>
</div>